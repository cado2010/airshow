# Local dev workaround: your network intercepts TLS (UNABLE_TO_VERIFY_LEAF_SIGNATURE),
# which made every registry request retry ~70s. Disabling strict-ssl for this
# project unblocks installs. For a more secure alternative, set NODE_EXTRA_CA_CERTS
# to your corporate root CA and remove this line.
strict-ssl=false
fund=false
audit=false
