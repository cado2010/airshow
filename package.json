{
  "name": "airshow",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time aircraft ceiling projection system using free ADS-B data",
  "workspaces": [
    "app",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,app -c blue,green \"npm:dev:server\" \"npm:dev:app\"",
    "dev:server": "npm -w server run dev",
    "dev:app": "npm -w app run dev",
    "build": "npm -w server run build && npm -w app run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "soaring-symbols": "^0.1.0-alpha.10"
  }
}
